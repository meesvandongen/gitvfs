{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "gitvfs": ["../gitvfs/src/index.ts"],
      "gitvfs/providers/github": ["../gitvfs/src/providers/github.ts"],
      "gitvfs/providers/gitlab": ["../gitvfs/src/providers/gitlab.ts"]
    }
  },
  "include": ["src"]
}
