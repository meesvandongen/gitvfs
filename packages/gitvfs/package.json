{
  "name": "gitvfs",
  "version": "0.1.0",
  "description": "Filesystem abstraction over Git provider APIs (GitHub, GitLab)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./providers/github": {
      "import": "./dist/providers/github.js"
    },
    "./providers/gitlab": {
      "import": "./dist/providers/gitlab.js"
    },
    "./cache/indexeddb": {
      "import": "./dist/cache/indexeddb.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0",
    "happy-dom": "^20.8.4"
  },
  "license": "MIT"
}
