# ── GitHub OIDC ───────────────────────────────────────────────────────────────
# OIDC issuer for GitHub authentication.
# When GitHub itself is the identity provider the access token issued can be
# used directly with the GitHub REST/GraphQL APIs.
# Example: a Keycloak realm that federates GitHub, or GitHub's own OAuth app
# configured as an OIDC provider (issuer: https://token.actions.githubusercontent.com
# is for Actions only – use your organisation's SSO or an OAuth proxy instead).
VITE_GITHUB_OIDC_ISSUER_URI=https://auth.example.com/realms/github-realm
VITE_GITHUB_OIDC_CLIENT_ID=git-fs-github-client

# ── GitLab OIDC ───────────────────────────────────────────────────────────────
# GitLab ships a built-in OIDC provider.  The access token issued here is
# accepted directly by the GitLab REST and GraphQL APIs.
# For gitlab.com use https://gitlab.com as the issuer.
# For a self-hosted instance use https://gitlab.example.com.
VITE_GITLAB_OIDC_ISSUER_URI=https://gitlab.com
VITE_GITLAB_OIDC_CLIENT_ID=your-gitlab-oauth-app-id

# Optional: base URL of a self-hosted GitLab instance (defaults to https://gitlab.com)
# VITE_GITLAB_API_URL=https://gitlab.example.com
