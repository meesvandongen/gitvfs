# OIDC Provider configuration
# Your OIDC issuer URI (e.g. Keycloak realm, Auth0 domain, Entra ID tenant)
VITE_OIDC_ISSUER_URI=https://auth.example.com/realms/myrealm

# The client ID registered with your OIDC provider
# The redirect URI must be set to http://localhost:3000 (or your app URL) in the provider
VITE_OIDC_CLIENT_ID=my-spa-client

# GitHub repository to browse
VITE_GITHUB_OWNER=my-org
VITE_GITHUB_REPO=my-repo

# Branch to read from (defaults to "main")
VITE_GITHUB_BRANCH=main
